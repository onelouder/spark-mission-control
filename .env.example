# Mission Control v2 example environment.
# Copy to .env and keep real secrets, tokens, and local URLs there.

POSTGRES_USER=mission_control
POSTGRES_PASSWORD=replace-with-a-local-db-password
POSTGRES_DB=mission_control
DATABASE_URL=postgresql+asyncpg://mission_control:replace-with-a-local-db-password@localhost:5433/mission_control
REDIS_URL=redis://localhost:6380/0
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000
DECAPODA_BASE_URL=http://localhost:8766

# Auth (optional in dev - set AUTH_ENABLED=false for local/tests)
AUTH_ENABLED=true
MISSION_CONTROL_USERNAME=admin
MISSION_CONTROL_PASSWORD_HASH=
SESSION_SECRET=replace-with-a-random-secret
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=8
AUTH_SELF_EMAIL=

# OpenClaw gateway. Leave blank to run Mission Control without gateway access.
MOLTBOT_GATEWAY_WS_URL=
MOLTBOT_TOKEN=
OPENCLAW_CONFIG_DIR=
MOLTBOT_GATEWAY_INSECURE_TLS=true

# Ether-Voice speech appliance. Leave blank when voice is not installed.
ETHER_VOICE_AGENT_WS_URL=
ETHER_VOICE_AGENT_AUTH=
ETHER_VOICE_PUBLIC_URL=
ETHER_VOICE_DEFAULT_VOICE=bm_daniel
ETHER_VOICE_WAKE_PHRASES=
ETHER_VOICE_AGENT_VOICES=
ETHER_VOICE_DEFAULT_MODEL=
ETHER_VOICE_AGENT_MODELS=
ETHER_VOICE_AGENT_WAKE_PHRASES=

# Project-Box (Flow Focus) - Obsidian-backed task system. Set PROJECTBOX_URL
# to an empty value to opt out.
PROJECTBOX_URL=http://127.0.0.1:5173
PROJECTBOX_PUBLIC_URL=http://127.0.0.1:5173
PROJECTBOX_TIMEOUT_SECONDS=5
PROJECTBOX_CACHE_TTL_SECONDS=30

# Twenty CRM. /crm redirects to the configured browser URL.
TWENTY_CRM_URL=http://127.0.0.1:3200
TWENTY_CRM_PUBLIC_URL=http://127.0.0.1:3200
