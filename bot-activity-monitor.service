[Unit]
Description=Bot Activity Monitor - Anomalous Bot Usage Detection
After=network.target
Wants=mission-control.service

[Service]
Type=exec
User=jwells
Group=jwells
WorkingDirectory=/home/jwells/projects/mission-control
Environment=PATH=/home/jwells/projects/mission-control/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/jwells/projects/mission-control/venv/bin/python /home/jwells/projects/mission-control/bot_monitor_cli.py daemon
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/home/jwells/projects/mission-control/data /home/jwells/projects/mission-control/logs

[Install]
WantedBy=multi-user.target