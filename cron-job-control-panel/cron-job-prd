4) Pull strategy scoring (V1 formula)

Normalize inputs:

priority already 0..100

age_hours = (now - created_at)/3600

stale_hours = (now - updated_at)/3600

blocked = len(blocked_by)>0

Weights:

PRIORITY_FIRST: wP=1.0, wA=0.2, wU=0.2

OLDEST_FIRST: wP=0.3, wA=1.0, wU=0.3

Blocked penalty: if avoid_blocked, filter; else -1000

Score:
score = wP*priority + wA*age_hours + wU*stale_hours - (blocked?1000:0)

5) Pseudocode (atomic lease semantics)
5.1 Acquire lease (single task)

Assumes Postgres is authority for lease lock; Kanban is updated after acquisition.

function try_acquire_lease(agent_id, task_id, now):
  cfg = load_agent_config(agent_id)

  begin transaction

  -- ensure task exists in cache (or insert placeholder)
  task = select * from tasks_cache where task_id = :task_id for update
  if task missing:
     rollback; return {ok:false, reason:"TASK_NOT_IN_CACHE"}

  -- scope checks
  if task.lane not in cfg.allowed_lanes:
     rollback; return {ok:false, reason:"REJECT_SCOPE", code:"INVALID_LANE"}

  if cfg.allowed_tags not empty and intersection(task.tags, cfg.allowed_tags) empty:
     rollback; return {ok:false, reason:"REJECT_SCOPE", code:"TAG_NOT_ALLOWED"}

  -- blocked avoidance
  if cfg.avoid_blocked and length(task.blocked_by) > 0:
     rollback; return {ok:false, reason:"REJECT_BLOCKED", blocked_by: task.blocked_by}

  -- required fields validation
  (valid, reasons) = validate_required_fields(task, cfg)
  if not valid:
     rollback; return {ok:false, reason:"REJECT_INVALID", reasons: reasons}

  -- check existing lease
  lease = select * from leases where task_id = :task_id for update
  if lease exists:
     if lease.expires_at > now and lease.state='ACTIVE':
        rollback; return {ok:false, reason:"LEASE_HELD", held_by: lease.agent_id, expires_at: lease.expires_at}
     else:
        -- expired/abandoned lease; takeover
        delete from leases where task_id = :task_id

  lease_token = uuid4()
  acquired_at = now
  expires_at = now + cfg.lease_ttl_sec
  max_expires_at = now + cfg.max_lease_age_sec

  insert into leases(task_id, agent_id, lease_token, acquired_at, renewed_at, expires_at, max_expires_at, last_progress_at, stuck_cycles, state)
    values(task_id, agent_id, lease_token, acquired_at, acquired_at, expires_at, max_expires_at, acquired_at, 0, 'ACTIVE')

  commit

  emit_event("acquisition.claim_success", {...})
  return {ok:true, lease_token, expires_at, max_expires_at}

5.2 Candidate selection + claim loop (batch)
function run_agent_once(agent_id):
  now = time()
  cfg = load_agent_config(agent_id)
  corr = uuid4()

  emit_event("acquisition.scan_started", {...}, corr)

  candidates = query_candidates(cfg, now)           -- from tasks_cache
  scored = []
  for task in candidates:
     if not scope_ok(task,cfg): continue
     if cfg.avoid_blocked and task.blocked_by not empty: continue
     (valid, reasons) = validate_required_fields(task,cfg)
     if not valid:
        emit_event("acquisition.reject_invalid", {task_id, reasons}, corr)
        continue
     score = compute_score(task,cfg,now)
     scored.append({task, score})

  sort scored by score desc
  emit_event("acquisition.candidates_evaluated", {...top5...}, corr)

  claimed = []
  for item in scored:
     if length(claimed) >= cfg.max_tasks_per_run: break
     emit_event("acquisition.claim_attempt", {task_id:item.task.task_id, score:item.score}, corr)
     res = try_acquire_lease(agent_id, item.task.task_id, now)
     if res.ok:
        claimed.append({task_id:item.task.task_id, lease_token:res.lease_token})
     else if res.reason == "LEASE_HELD":
        emit_event("acquisition.claim_conflict", {...}, corr)
     else if res.reason startswith "REJECT_":
        -- already emitted reject_invalid; emit blocked/scope as needed
        pass

  return claimed

5.3 Renew lease (heartbeat) + progress

Renew and progress are distinct: renew extends TTL; progress updates last_progress_at.

function renew_lease(agent_id, task_id, lease_token, now):
  cfg = load_agent_config(agent_id)
  begin transaction
  lease = select * from leases where task_id=:task_id for update
  if lease missing: rollback; return {ok:false, reason:"NO_LEASE"}
  if lease.agent_id != agent_id or lease.lease_token != lease_token:
     rollback; return {ok:false, reason:"NOT_OWNER"}

  new_expires = min(now + cfg.lease_ttl_sec, lease.max_expires_at)
  if new_expires <= now:
     -- max lease age reached
     rollback; return {ok:false, reason:"MAX_LEASE_AGE_REACHED"}

  update leases set renewed_at=now, expires_at=new_expires where task_id=:task_id
  commit
  emit_event("lease.renewed", {...})
  return {ok:true, expires_at:new_expires}

function mark_progress(agent_id, task_id, lease_token, now, step, message, artifacts_added, checklist_done, checklist_total):
  begin transaction
  lease = select * from leases where task_id=:task_id for update
  if missing or not owner: rollback; return {ok:false, reason:"NOT_OWNER"}

  update leases set last_progress_at=now where task_id=:task_id
  commit

  emit_event("lease.progress", {
    task_id, lease_token, step, message,
    checklist_done, checklist_total,
    artifacts_added
  })
  return {ok:true}

5.4 Release lease (complete / handoff / auto-release)
function release_lease(agent_id, task_id, lease_token, now, reason, delivered, final_artifacts):
  begin transaction
  lease = select * from leases where task_id=:task_id for update
  if lease missing: rollback; return {ok:false, reason:"NO_LEASE"}
  if lease.agent_id != agent_id or lease.lease_token != lease_token:
     rollback; return {ok:false, reason:"NOT_OWNER"}

  delete from leases where task_id=:task_id
  commit

  emit_event("lease.released", {task_id, lease_token, reason, delivered, final_artifacts})
  return {ok:true}

5.5 Stuck detection loop (global cron, every 5–10 min)
function stuck_sweeper():
  now = time()
  for each lease in leases where state='ACTIVE':
     cfg = load_agent_config(lease.agent_id)
     inactive = now - lease.last_progress_at

     if inactive < cfg.stuck_after_sec:
        continue

     -- emit detected
     emit_event("stuck.detected", {...action:"PING"...})

     if inactive < cfg.stuck_after_sec + cfg.stuck_grace_sec:
        continue

     -- auto-release + escalate cycle count
     begin transaction
     lease2 = select * from leases where task_id=lease.task_id for update
     if lease2 missing: rollback; continue
     -- re-check under lock
     inactive2 = now - lease2.last_progress_at
     if inactive2 < cfg.stuck_after_sec + cfg.stuck_grace_sec:
        rollback; continue

     cycles = lease2.stuck_cycles + 1
     -- release
     delete from leases where task_id=lease.task_id
     commit

     emit_event("lease.released", {reason:"AUTO_RELEASE_STUCK", ...})
     emit_event("stuck.detected", {...action:"AUTO_RELEASE", stuck_cycles:cycles...})

     if cycles >= cfg.stuck_max_cycles:
        -- handoff: mark in Kanban + cache (NEEDS_ATTENTION tag/lane)
        emit_event("stuck.detected", {...action:"HANDOFF"...})
        kanban_move_to_needs_attention(lease.task_id)

