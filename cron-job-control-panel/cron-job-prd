function validate_required_fields(task, cfg):
  reasons = []
  if cfg.require_acceptance and (task.acceptance_criteria is null or len(trim(task.acceptance_criteria)) < 20):
     reasons.append("MISSING_ACCEPTANCE_CRITERIA")
  if cfg.require_output_target and (task.output_target_type is null or task.output_target_ref is null):
     reasons.append("MISSING_OUTPUT_TARGET")
  if cfg.require_owner and (task.owner is null or trim(task.owner) == ""):
     reasons.append("MISSING_OWNER")
  if cfg.require_links and (task.links is empty):
     reasons.append("MISSING_LINKS")
  return (len(reasons)==0, reasons)

